{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@flyntos/config": ["../../packages/config/src/index.ts"],
      "@flyntos/i18n": ["../../packages/i18n/src/index.ts"],
      "@flyntos/seo-engine": ["../../packages/seo-engine/src/index.ts"],
      "@flyntos/shared": ["../../packages/shared/src/index.ts"],
      "@flyntos/ui": ["../../packages/ui/src/index.tsx"],
      "@flyntos/search-contracts": ["../../packages/search-contracts/src/index.ts"],
      "@flyntos/provider-sdk": ["../../packages/provider-sdk/src/index.ts"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "jsx": "preserve",
    "noEmit": true,
    "allowJs": true,
    "incremental": true,
    "isolatedModules": true
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
